{
    "name": "lt-marketplace/lt-marketplace-suite",
    "description": "Enterprise Multi-Vendor WooCommerce Plugin for Colombia & Mexico",
    "type": "wordpress-plugin",
    "version": "1.5.0",
    "license": "proprietary",
    "authors": [
        {
            "name": "LT Marketplace Team",
            "email": "dev@ltmarketplace.co"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-openssl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-curl": "*",
        "ext-bcmath": "*",
        "dompdf/dompdf": "^2.0",
        "firebase/php-jwt": "^6.10",
        "ramsey/uuid": "^4.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "brain/monkey": "^2.6",
        "mockery/mockery": "^1.6",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.7",
        "wp-coding-standards/wpcs": "^3.0",
        "phpcompatibility/php-compatibility": "^9.3"
    },
    "autoload": {
        "psr-4": {
            "LTMS\\": "includes/"
        },
        "classmap": [
            "includes/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "LTMS\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpcs": "phpcs --standard=WordPress includes/",
        "phpstan": "phpstan analyse includes/ --level=6",
        "build": "bin/build.sh",
        "post-install-cmd": [
            "@php -r \"copy('vendor/autoload.php', 'vendor/autoload.php');\""
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "classmap-authoritative": false,
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "extra": {
        "installer-name": "lt-marketplace-suite"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
