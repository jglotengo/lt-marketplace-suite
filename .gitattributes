# ============================================================
# LT Marketplace Suite - .gitattributes
# ============================================================

# Normalización de finales de línea
* text=auto eol=lf

# PHP
*.php text eol=lf

# Web
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.json text eol=lf

# Docs
*.md   text eol=lf
*.txt  text eol=lf

# Config
*.yml  text eol=lf
*.yaml text eol=lf
*.xml  text eol=lf
*.ini  text eol=lf

# Scripts (Unix)
*.sh   text eol=lf

# Binarios (no modificar finales de línea)
*.png  binary
*.jpg  binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.zip  binary
*.gz   binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary

# Exclusiones del artefacto de distribución (.distignore se usa con WP-CLI)
.gitattributes export-ignore
.gitignore     export-ignore
.editorconfig  export-ignore
.vscode/       export-ignore
.github/       export-ignore
tests/         export-ignore
bin/           export-ignore
docs/          export-ignore
docker-compose*.yml export-ignore
Makefile       export-ignore
phpunit.xml    export-ignore
phpcs.xml      export-ignore
phpstan.neon   export-ignore
